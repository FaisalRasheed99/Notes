    "s = input(\"Enter word : \")\n",
    "def palindrome(s):\n",
    "    rev = s[::-1]\n",
    "    if rev == s:\n",
    "        print(\"Its Palindrome\")\n",
    "    else:\n",
    "        print(\"Its not palindrome\")\n",
    "    \n",
    "palindrome(s)"
